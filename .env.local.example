# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Turnstile CAPTCHA Keys (Obtain from Cloudflare Dashboard -> Turnstile)
VITE_TURNSTILE_SITEKEY=your-turnstile-sitekey-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

